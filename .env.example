# Opzionale: fuso IANA recap Command Center se nessun utente ha `User.timeZone` in /admin/settings. Esempio: Europe/Rome.
# ONIZUKA_RECAP_TIMEZONE=Europe/Rome

# Database (PostgreSQL)
# Production Vercel + Supabase:
#   DATABASE_URL = Transaction pooler (porta 6543, ?pgbouncer=true) — runtime app
#   DIRECT_URL   = connessione diretta (porta 5432) — solo `prisma migrate deploy`
# Vedi docs/DEPLOY.md
DATABASE_URL="postgresql://user:password@localhost:5432/approval_portal?schema=public"
DIRECT_URL="postgresql://user:password@localhost:5432/approval_portal?schema=public"
# Sviluppo con Docker (immagine pgvector/pgvector:pg16 — `npm run db:up`) → stesso URL per entrambe:
# DATABASE_URL="postgresql://onizuka:onizuka@127.0.0.1:5433/onizuka?schema=public"
# DIRECT_URL="postgresql://onizuka:onizuka@127.0.0.1:5433/onizuka?schema=public"

# NextAuth
# Sviluppo: localhost ok. Produzione: NEXTAUTH_URL=https://... e NEXTAUTH_SECRET >= 32 caratteri casuali.
# `next build` in produzione fallisce se mancano, sono troppo corti o sembrano placeholder.
NEXTAUTH_URL="http://localhost:3000"
# Produzione onizuka.it: NEXTAUTH_URL=https://onizuka.it
# Redirect www → apex (next.config): ONIZUKA_PRIMARY_HOST=onizuka.it
# Ambiente logico: development | staging | production
# ONIZUKA_ENV=staging
# Su staging: ref Supabase atteso nel DATABASE_URL (es. abcdef da db.abcdef.supabase.co)
# ONIZUKA_STAGING_DB_MARKER=abcdef
# Export memoria CSV senza maschera: 0 per disabilitare
# ONIZUKA_ALLOW_UNMASKED_MEMORY_EXPORT=1
# Se `next dev` usa un'altra porta (es. 3001), allinea NEXTAUTH_URL: http://localhost:3001
NEXTAUTH_SECRET="dev-only-use-openssl-rand-base64-32-for-real-secret-min-32-chars"

# Opzionale: Redis TCP per rate limit globale su /api/n8n/* e API admin (mutazioni). Node only.
# Con REDIS_URL attivo anche coda automazioni multi-worker + DLQ Redis (oltre Postgres).
# REDIS_URL=redis://localhost:6379

# Coda automazioni AWS SQS (prioritaria su Redis se configurata)
# AUTOMATION_SQS_QUEUE_URL=https://sqs.eu-west-1.amazonaws.com/123/onizuka-automation
# AUTOMATION_SQS_DLQ_URL=https://sqs.eu-west-1.amazonaws.com/123/onizuka-automation-dlq
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=eu-west-1

# Badge partner ERP ufficiale (dopo accordo vendor) — anche UI /admin/settings
# ZUCCHETTI_PARTNER_OFFICIAL=1
# SAP_PARTNER_OFFICIAL=1

# Provisioning DB tenant cloud
# SUPABASE_ACCESS_TOKEN=  # Management API
# SUPABASE_ORG_ID=
# SUPABASE_REGION=eu-central-1
# ONIZUKA_SUPABASE_POOLER_TEMPLATE=postgresql://postgres.{ref}:{password}@aws-0-eu-central-1.pooler.supabase.com:6543/postgres?pgbouncer=true
# ONIZUKA_RDS_MASTER_URL=postgresql://admin:pass@rds-host:5432/postgres

# Dedupe training GPU (webhook worker esterno + callback)
# DEDUPE_GPU_WEBHOOK_URL=https://gpu-worker.example/train
# DEDUPE_GPU_WEBHOOK_SECRET=

# SSO agenzia Microsoft Entra ID (admin/staff — email deve esistere in User)
# AZURE_AD_CLIENT_ID=
# AZURE_AD_CLIENT_SECRET=
# AZURE_AD_TENANT_ID=common

# Workspace enterprise: map slug/id → connection string (alternativa a Workspace.databaseUrl in UI)
# ONIZUKA_WORKSPACE_DATABASES={"ws_agency_b":"postgresql://..."}

# Opzionale: Upstash Redis REST per rate limit login nel middleware (Edge-compatible).
# Se entrambe mancano, login limit in-memory per istanza.
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=

# Integrazioni (stub MVP — collegare OAuth in produzione)
# Google Calendar OAuth (Impostazioni → Collega)
# GOOGLE_CALENDAR_CLIENT_ID=
# GOOGLE_CALENDAR_CLIENT_SECRET=
# GOOGLE_CALENDAR_REDIRECT_URI=https://onizuka.it/api/integrations/google-calendar/callback
# GMAIL_CLIENT_ID= (può coincidere con Calendar se stesso progetto Google Cloud)
# GMAIL_CLIENT_SECRET=
# GMAIL_REDIRECT_URI=https://onizuka.it/api/integrations/gmail/callback
# LLM opzionale per "Chiedi a Onizuka"
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini
# OPENAI_EMBEDDING_MODEL=text-embedding-3-small
# ONIZUKA_EMBEDDINGS=0
# Google Drive API (service account JSON one-line, cartelle cliente automatiche)
# GOOGLE_DRIVE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}
# GOOGLE_DRIVE_PARENT_FOLDER_ID=optional_shared_parent_folder_id
# Sito marketing Hostinger (opzionale, link vetrina)
# ONIZUKA_MARKETING_URL=https://landing.onizuka.it
# Telegram bot
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_WEBHOOK_SECRET=
# TELEGRAM_ADMIN_CHAT_IDS=123456789
# GMAIL_CLIENT_ID=
# GMAIL_CLIENT_SECRET=
# Invio MVP Reach: mailto nel browser. SMTP opzionale (send API in roadmap):
# GMAIL_SMTP_HOST=smtp.gmail.com
# GMAIL_SMTP_PORT=587
# GMAIL_SMTP_SECURE=0
# GMAIL_SMTP_USER=
# GMAIL_SMTP_PASSWORD=
# GMAIL_SMTP_FROM=onboarding@resend.dev
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_WEBHOOK_SECRET=
# VOICE_TTS_PROVIDER=elevenlabs  # opzionale; MVP usa Web Speech nel browser
# Google Places API (audit GBP: rating e recensioni live)
# GOOGLE_PLACES_API_KEY=
# Google Sheet → coda audit digitale (EP03): CSV pubblico o export da spreadsheet ID
# GOOGLE_SHEET_AUDIT_CSV_URL=https://docs.google.com/spreadsheets/d/.../export?format=csv&gid=0
# GOOGLE_SHEET_AUDIT_SPREADSHEET_ID=
# GOOGLE_SHEET_AUDIT_GID=0
# Sheets API privato (stesso JSON del Drive o dedicato):
# GOOGLE_SHEETS_SERVICE_ACCOUNT_JSON={"type":"service_account",...}
# GOOGLE_SHEET_AUDIT_RANGE=Sheet1!A:Z
# GOOGLE_SHEET_AUTO_SYNC_CRON=1
# Cron coda audit: GET /api/cron/audit-sheet-queue (header Bearer CRON_SECRET)
# Publish nativo Social Pro
# NB: questi token env sono il fallback SINGLE-ACCOUNT (solo le pagine di Lorenzo).
# Il Publisher multi-tenant usa i token cifrati per-cliente in SocialAccount.tokenCipher
# (cifratura via NEXTAUTH_SECRET, vedi src/lib/social-account.ts).
# META_PAGE_ACCESS_TOKEN=
# META_PAGE_ID=
# LINKEDIN_ACCESS_TOKEN=
# LINKEDIN_AUTHOR_URN=urn:li:organization:12345
# Scheduler pubblicazione nativa multi-account: GET /api/cron/social-publish (Bearer CRON_SECRET).
# Pubblica i post APPROVED con scheduledFor scaduto e socialAccountId valorizzato.
# SOCIAL_PUBLISH_CRON=0  # per disabilitare lo scheduler
# Ingest automatico metriche (impression/reach/engagement) dei post pubblicati via account collegato:
# GET /api/cron/social-metrics (Bearer CRON_SECRET). Meta implementato; LinkedIn/GBP Fase 3+.
# SOCIAL_METRICS_CRON=0  # per disabilitare l'ingest metriche
# "Team di esperti" AI: rigenera e salva le raccomandazioni social per cliente (panel multi-lente
# + sintesi). GET /api/cron/social-insights (Bearer CRON_SECRET). Richiede OPENAI_API_KEY per l'AI
# (altrimenti degrada a sintesi rule-based). SOCIAL_INSIGHTS_CRON=0 per disabilitare.
# Analytics — Google Analytics 4 (Blocco 2): OAuth Google (riusa GOOGLE_GBP_/CALENDAR_ o dedicato).
# GOOGLE_ANALYTICS_CLIENT_ID=
# GOOGLE_ANALYTICS_CLIENT_SECRET=
# GOOGLE_ANALYTICS_REDIRECT_URI=https://onizuka.it/api/integrations/ga4/callback
# Collector GA4 (traffico sito): GET /api/cron/analytics-ga4 (Bearer CRON_SECRET). ANALYTICS_GA4_CRON=0 disabilita.
# GA4_API_BASE=  # override endpoint Data API (solo per test/mock; default https://analyticsdata.googleapis.com)
# Snapshot social (Blocco 3): follower nel tempo + reach/impression a livello account (Meta).
# GET /api/cron/social-snapshots (Bearer CRON_SECRET). SOCIAL_SNAPSHOTS_CRON=0 disabilita.
# META_GRAPH_BASE=  # override endpoint Graph (solo per test/mock; default https://graph.facebook.com/v19.0)
# Advertising (Blocco 4): Meta Ads (Marketing API) + Google Ads (GAQL). Token per-connessione cifrato.
# GET /api/cron/analytics-ads (Bearer CRON_SECRET). ANALYTICS_ADS_CRON=0 disabilita.
# GOOGLE_ADS_DEVELOPER_TOKEN=   # richiesto per Google Ads API
# GOOGLE_ADS_API_BASE=          # override endpoint (test/mock; default https://googleads.googleapis.com/v17)
# Google Business Profile publish nativo (localPosts) — fallback env single-account.
# Token OAuth scade ~1h: in multi-tenant usare il token per-account in SocialAccount.tokenCipher.
# GOOGLE_GBP_ACCESS_TOKEN=
# (GOOGLE_GBP_LOCATION_NAME già documentato sotto, sezione GBP OAuth)
# Limite progetti Supabase org (default 10)
# SUPABASE_MAX_ACTIVE_PROJECTS=10
# Memoria HIGH cifrata at-rest (min 16 caratteri)
# ONIZUKA_MEMORY_ENCRYPTION_KEY=
# PIN opzionale per export CSV senza maschera (param vaultPin)
# ONIZUKA_MEMORY_VAULT_PIN=
# Chiave precedente dopo rotazione (decrypt legacy + pulsante ri-cifra in /admin/memory)
# ONIZUKA_MEMORY_ENCRYPTION_KEY_PREVIOUS=
# Cache MP3 TTS su disco (0 per disabilitare)
# VOICE_TTS_CACHE=1
# OPENAI_TTS_VOICE=nova
# ElevenLabs TTS (VOICE_TTS_PROVIDER=elevenlabs)
# ELEVENLABS_API_KEY=
# ELEVENLABS_VOICE_ID=
# ELEVENLABS_MODEL_ID=eleven_multilingual_v2
# pgvector ANN search (default on; 0 per disabilitare)
# ONIZUKA_PGVECTOR=0
# Export FatturaPA XML
# ONIZUKA_ISSUER_NAME=Lorenzo Matarazzo
# ONIZUKA_ISSUER_VAT=IT00000000000
# Google Business Profile OAuth (audit recensioni; può riusare credenziali Calendar)
# GOOGLE_GBP_CLIENT_ID=
# GOOGLE_GBP_CLIENT_SECRET=
# GOOGLE_GBP_REDIRECT_URI=https://onizuka.it/api/integrations/gbp-business/callback
# Risposte recensioni live (resource name location da Google Business Profile)
# GOOGLE_GBP_LOCATION_NAME=accounts/ACCOUNT_ID/locations/LOCATION_ID
# Bridge SDI / fatturazione elettronica (roadmap invio automatico)
# ONIZUKA_SDI_ENDPOINT=
# ONIZUKA_SDI_API_KEY=
# Stripe (pagamenti portale — webhook /api/webhooks/stripe)
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# Conti PDC default export gestionale (override per cliente: campo accountingCode su Client)
# ONIZUKA_FINANCE_INCOME_RECEIVED_ACCOUNT=5810
# ONIZUKA_FINANCE_INCOME_EXPECTED_ACCOUNT=4105
# ONIZUKA_FINANCE_EXPENSE_PAID_ACCOUNT=6805
# ONIZUKA_FINANCE_EXPENSE_OPEN_ACCOUNT=2605
# Contropartite export doppia registrazione (banca / crediti / debiti)
# ONIZUKA_FINANCE_BANK_ACCOUNT=1801
# ONIZUKA_FINANCE_RECEIVABLE_ACCOUNT=1205
# ONIZUKA_FINANCE_PAYABLE_ACCOUNT=2605

# Notifica email al cliente quando aggiorni un ticket (richiede GMAIL_SMTP_*). Disabilita con 0.
# TICKET_NOTIFY_EMAIL=1

# Invio preventivo via SMTP al contactEmail del cliente. Disabilita con 0.
# QUOTE_NOTIFY_EMAIL=1

# Digest email riepilogo notifiche non lette (richiede GMAIL_SMTP_*). Disabilita con 0.
# NOTIFY_DIGEST_EMAIL=1

# Cron giornaliero: GET /api/cron/notifications con Authorization: Bearer <CRON_SECRET>
# Esegue promemoria Flow (scadenza oggi / in ritardo) e opzionalmente digest email a utenti con non lette.
# NOTIFY_DIGEST_CRON=0  # disabilita solo l'invio email nel cron (i promemoria in-app restano attivi)
# Digest operativo settimanale (lun default, invio a tutti gli ADMIN via cron notifications)
# OPS_WEEKLY_DIGEST_CRON=0
# OPS_WEEKLY_DIGEST_WEEKDAY=1
# OPS_WEEKLY_DIGEST_FORCE=1
# CRON_SECRET=genera-con-openssl-rand-hex-32
# Vercel: vercel.json schedula /api/cron/notifications (06:00 UTC). Imposta CRON_SECRET in env Vercel.
# GitHub Actions: secrets ONIZUKA_CRON_URL=https://…/api/cron/notifications e CRON_SECRET (workflow cron-notifications.yml).
# Scan dedupe notturno (cap 10k) nel cron notifications: DEDUPE_SCAN_CRON=1
# Email alert se scan trova gruppi duplicati: DEDUPE_ALERT_EMAIL_CRON=1
# DEDUPE_ALERT_MIN_GROUPS=3
# Promemoria rinnovi MRR (Finance renewalDate): FINANCE_RENEWAL_CRON=1
# Follow-up lead schedulati: LEAD_FOLLOWUP_CRON=0 per disabilitare
# Reminder preventivo «proposta non risposta»: QUOTE_NO_RESPONSE_CRON=0 per disabilitare
# Refresh intelligence NBA: INTELLIGENCE_REFRESH_CRON=0 per disabilitare
# SLA opportunità in stallo: OPPORTUNITY_SLA_CRON=0 per disabilitare
# Seguito meeting Flow [Meeting]: MEETING_FOLLOWTHROUGH_CRON=0 per disabilitare
# GHA audit sheet: ONIZUKA_CRON_AUDIT_SHEET_URL + CRON_SECRET (cron-audit-sheet-queue.yml)
# GHA dedupe training: ONIZUKA_CRON_DEDUPE_URL + CRON_SECRET (cron-dedupe-training.yml)

# WhatsApp Business Cloud API (Meta)
# WHATSAPP_ACCESS_TOKEN=
# WHATSAPP_PHONE_NUMBER_ID=
# WHATSAPP_VERIFY_TOKEN=   # hub.verify_token per GET /api/integrations/whatsapp/webhook
# App Secret dell'app Meta: verifica firma HMAC-SHA256 (header X-Hub-Signature-256) sugli
# inbound POST. Se assente il webhook resta fail-open (accetta ma logga un warning). Impostare
# in produzione per rifiutare i payload non firmati (401).
WHATSAPP_APP_SECRET=

# Portale segnalatore — Google SSO (può riusare credenziali Calendar/Gmail)
# REFERRER_GOOGLE_CLIENT_ID=
# REFERRER_GOOGLE_CLIENT_SECRET=
# Portale segnalatore — Microsoft Entra ID
# REFERRER_MICROSOFT_CLIENT_ID=
# REFERRER_MICROSOFT_CLIENT_SECRET=
# REFERRER_MICROSOFT_TENANT=common

# Social Pro — sync commenti pagina Facebook (Graph API)
# META_PAGE_ACCESS_TOKEN=
# META_PAGE_ID=
# LINKEDIN_ACCESS_TOKEN=
# LINKEDIN_ORGANIZATION_URN=urn:li:organization:123456
# INSTAGRAM_BUSINESS_ACCOUNT_ID=
# WHATSAPP_BUSINESS_ACCOUNT_ID=   # sync template HSM
# ZUCCHETTI_API_URL=
# ZUCCHETTI_API_KEY=
# ZUCCHETTI_OAUTH_CLIENT_ID=
# ZUCCHETTI_OAUTH_CLIENT_SECRET=
# ZUCCHETTI_OAUTH_AUTH_URL=
# ZUCCHETTI_OAUTH_TOKEN_URL=
# SAP_API_URL=
# SAP_API_KEY=
# SAP_OAUTH_CLIENT_ID=
# SAP_OAUTH_CLIENT_SECRET=
# SAP_OAUTH_TENANT=common
# Dedupe embedding locale (senza OpenAI): ONIZUKA_DEDUPE_LOCAL=1
# AUTOMATION_QUEUE_CRON=0

# Push ore verso ERP esterno (JSON + CSV nel body)
# TIME_ERP_WEBHOOK_URL=https://erp.example.com/onizuka/time
# TIME_ERP_WEBHOOK_SECRET=
# Probe pull bidirezionale SAP/ERP (HEAD su endpoint)
# TIME_ERP_PULL_URL=https://erp.example.com/onizuka/health
# TIME_ERP_PULL_SECRET=

# Web Push portale segnalatore (/refer) — npm package web-push
# VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=
# VAPID_SUBJECT=mailto:ops@your-agency.it

# SLA ticket portale (ore, default 48). Cron breach in /api/cron/notifications
# TICKET_SLA_HOURS=48
# TICKET_SLA_CRON=1

# n8n API (for GET /api/n8n/approved and POST /api/n8n/mark-published)
# Use X-API-Key or Authorization: Bearer <key> in requests
N8N_API_KEY=

# Storage: S3-compatible (R2 / AWS S3) or filesystem fallback (dev only)
# Production (e.g. Vercel): S3/R2 is required. Set S3_BUCKET, S3_ACCESS_KEY, S3_SECRET_KEY.
# S3_ENDPOINT=          # e.g. https://xxx.r2.cloudflarestorage.com
# S3_REGION=auto        # "auto" for R2
# S3_BUCKET=
# S3_ACCESS_KEY=
# S3_SECRET_KEY=
# S3_PUBLIC_URL=        # Optional: base URL for public object links
# S3_FORCE_PATH_STYLE=  # Set for R2/minio
# UPLOADS_DIR=.uploads  # Local fallback only (default .uploads)
# Produzione su VPS con disco persistente (no S3): ALLOW_LOCAL_UPLOAD_SERVE=1 — abilita anche GET /api/uploads (con sessione).
# ALLOW_LOCAL_UPLOAD_SERVE=1

# Seed / CI: ONIZUKA_E2E=1 disabilita mustChangePassword su account demo (Playwright CI).
# ONIZUKA_E2E=1
