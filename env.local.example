# Copia in .env.local (gitignored) oppure genera con:
#   npm run local:setup
#
# Dopo ogni modifica: riavvia `npm run dev`.

# Cron locale (Bearer su /api/cron/*)
CRON_SECRET=genera-con-openssl-rand-hex-32

# Storage filesystem in dev/prod self-hosted (health → storage: local)
ALLOW_LOCAL_UPLOAD_SERVE=1
