# =============================================================================
# Onizuka — ambiente STAGING (copia in .env.staging, NON committare segreti)
# =============================================================================
# Obbligatorio per script: staging:migrate, staging:seed, staging:cleanup (remoto)
# Conferma operazioni rischiose: ONIZUKA_STAGING_CONFIRM=yes
#
# MAI usare URL/credenziali produzione (onizuka.it, DB prod).
# =============================================================================

# --- Obbligatori (staging remoto) ---
ONIZUKA_ENV=staging
# Ref Supabase staging (es. abcdef da db.abcdef.supabase.co) — DEVE comparire in DATABASE_URL
ONIZUKA_STAGING_DB_MARKER=your_supabase_project_ref
# Conferma esplicita migrate/seed/cleanup: yes
# ONIZUKA_STAGING_CONFIRM=yes

# URL pubblico app staging (Vercel staging o staging.onizuka.it)
NEXTAUTH_URL=https://your-staging-app.vercel.app
NEXTAUTH_SECRET=generate-with-openssl-rand-base64-32-min-32-chars

# Pooler runtime (6543) + direct migrate (5432)
DATABASE_URL=postgresql://postgres.YOUR_REF:PASSWORD@aws-0-eu-central-1.pooler.supabase.com:6543/postgres?pgbouncer=true
DIRECT_URL=postgresql://postgres:PASSWORD@db.YOUR_REF.supabase.co:5432/postgres

# E2E remoti (stesso host di NEXTAUTH_URL)
PLAYWRIGHT_BASE_URL=https://your-staging-app.vercel.app

# --- Consigliati (disabilita invii reali) ---
QUOTE_NOTIFY_EMAIL=0
TICKET_NOTIFY_EMAIL=0
NOTIFY_DIGEST_EMAIL=0
NOTIFY_DIGEST_CRON=0
OPS_WEEKLY_DIGEST_CRON=0
DEDUPE_ALERT_EMAIL_CRON=0

# Probe audit: mock in E2E; su staging reale resta fetch — usa domini example.test nei test
# PLAYWRIGHT_E2E=1  # solo per run Playwright, non su Vercel runtime

# Cron Vercel staging (CRON_SECRET dedicato staging, diverso da prod)
CRON_SECRET=generate-staging-cron-secret

# Storage staging (bucket separato)
S3_BUCKET=onizuka-staging-media
# S3_ENDPOINT=
# S3_ACCESS_KEY=
# S3_SECRET_KEY=
# S3_PUBLIC_URL=

# Email sandbox (opzionale — se assente, invio quote disabilitato)
# GMAIL_SMTP_HOST=smtp.mailtrap.io
# GMAIL_SMTP_PORT=587
# GMAIL_SMTP_USER=
# GMAIL_SMTP_PASSWORD=
# GMAIL_SMTP_FROM=staging@example.test

# --- Opzionali ---
ONIZUKA_RECAP_TIMEZONE=Europe/Rome
N8N_API_KEY=staging-n8n-key-if-needed

# Seed/E2E account demo senza mustChangePassword (impostato da script seed)
# ONIZUKA_E2E=1
