// Onizuka — schema operativo (MVP in evoluzione verso master spec).
// Multi-tenant: admin vs client; moduli Flow (task), CRM (clienti), approvazioni contenuti, webhook n8n.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  ADMIN
  STAFF
  CLIENT
}

enum Platform {
  FACEBOOK
  INSTAGRAM
  LINKEDIN
  GBP
}

enum PostStatus {
  PENDING
  APPROVED
  NEEDS_REVISION
}

enum MediaType {
  IMAGE
  VIDEO
}

enum WebhookEvent {
  POST_APPROVED
  POST_STATUS_CHANGED
}

enum WebhookDeliveryStatus {
  FAILED
  DELIVERED
}

enum OAuthProvider {
  GOOGLE_CALENDAR
  GMAIL
  GOOGLE_GBP
  ZUCCHETTI_ERP
  SAP_ERP
}

enum AutomationFlowRunStatus {
  PENDING
  RUNNING
  DONE
  FAILED
}

enum FlowTaskStatus {
  TODO
  IN_PROGRESS
  WAITING
  DONE
  CANCELLED
}

enum FlowTaskPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum MemoryScope {
  PERSONAL
  BUSINESS
  ASSET
  CLIENT
  EPISODIC
  DOCUMENTAL
  SENSITIVE
}

enum MemorySensitivity {
  LOW
  MEDIUM
  HIGH
}

enum MemorySource {
  MANUAL
  VOICE
  CHAT
  DOCUMENT
  SYSTEM
}

enum ClientStatus {
  LEAD_COLD
  LEAD_QUALIFIED
  CONTACTED
  INTERESTED
  APPOINTMENT_SET
  QUOTE_SENT
  NEGOTIATION
  ACTIVE_CLIENT
  DORMANT
  LOST
  TO_REACTIVATE
}

/// Privato (CF) vs azienda (P.IVA) — PUNTO-SITUA-DEFINITIVO.
enum ClientKind {
  PRIVATE
  BUSINESS
}

/// Macro-categoria commerciale cliente.
enum ClientMacroCategory {
  RETAIL_STORE
  DIGITAL_AI
  MIXED
}

/// Stati funnel prospect digitali/AI (workflow P.IVA).
enum CommercialProspectStage {
  PROSPECT_ENTERED
  AUDIT_IN_PROGRESS
  AUDIT_COMPLETED
  REPORT_GENERATED
  PROPOSAL_GENERATED
  AWAITING_SEND_APPROVAL
  FIRST_AUDIT_MAIL_SENT
  FOLLOW_UP_SCHEDULED
  FOLLOW_UP_SENT
  RESPONSE_RECEIVED
  CALL_SCHEDULED
  QUOTE_SENT
  IN_NEGOTIATION
  WON
  LOST
  NURTURING
}

enum LeadStatus {
  NEW
  COLD
  QUALIFIED
  CONTACTED
  CONVERTED
  LOST
}

enum ReferrerPayoutStatus {
  PENDING
  PAID
}

enum OpportunityStatus {
  OPEN
  WON
  LOST
  PAUSED
}

enum OpportunityPriority {
  LOW
  MEDIUM
  HIGH
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

enum OutreachDraftStatus {
  DRAFT
  PENDING_APPROVAL
  APPROVED
  SENT
  CANCELLED
}

enum OutreachSequenceStatus {
  ACTIVE
  PAUSED
  COMPLETED
  CANCELLED
}

enum OutreachSequenceStepStatus {
  SCHEDULED
  ACTIVATED
  SENT
  SKIPPED
  CANCELLED
}

enum QuoteStatus {
  DRAFT
  SENT
  ACCEPTED
  REJECTED
}

/// Catalogo servizi tracciabili (telefonia, SEO, hosting…).
enum CommercialServiceCategory {
  TELECOM
  ENERGY
  WEB
  MARKETING
  BRANDING
  AUTOMATION
  CONSULTING
  OTHER
}

/// Audit digitale marketing (distinto da AdminAuditLog sicurezza).
enum DigitalAuditStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
}

enum AuditSheetQueueStatus {
  PENDING
  PROCESSING
  DONE
  FAILED
  SKIPPED
}

enum DigitalAuditSectionKey {
  WEBSITE
  SEO
  LOCAL
  REVIEWS
  SOCIAL
  ADV
  UX
  CONVERSION
  TRACKING
  BRAND
}

enum FinanceEntryType {
  INCOME
  EXPENSE
}

enum FinanceEntryStatus {
  PLANNED
  EXPECTED
  RECEIVED
  PAID
  OVERDUE
}

model User {
  id           String   @id @default(cuid())
  name         String?
  email        String   @unique
  passwordHash String?  // null if using OAuth later
  role         Role
  clientId     String?
  /// Moduli admin consentiti per STAFF (whitelist). Vuoto = policy predefinita.
  staffAllowedModules String[] @default([])
  /// Variante Reach predefinita dopo vincitore A/B (A o B).
  reachAbDefaultVariant String?
  timeZone     String?  // IANA es. Europe/Rome — recap Command Center / scadenze "oggi"
  notifyDigestEmail Boolean @default(true)
  mustChangePassword Boolean @default(false)
  /// STAFF: può approvare la 1ª firma su time entry (2ª resta solo ADMIN).
  canApproveTimeEntries Boolean @default(false)
  /// Commesse (projectCode) che lo STAFF può approvare; vuoto = tutte (se canApproveTimeEntries).
  timeApproverProjectCodes String[] @default([])
  /// Clienti che lo STAFF può approvare (1ª firma); vuoto = tutti (se canApproveTimeEntries).
  timeApproverClientIds    String[] @default([])
  /// Soglia gruppi dedupe per email alert (null = env DEDUPE_ALERT_MIN_GROUPS).
  dedupeAlertMinGroups     Int?
  workspaceId              String?  @default("ws_default")
  /// Azioni admin vietate esplicitamente (es. client.delete, finance.export).
  staffDeniedActions       String[] @default([])
  notificationRev   Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  client    Client?    @relation(fields: [clientId], references: [id], onDelete: SetNull)
  oauthConnections UserOAuthConnection[]
  comments    Comment[]
  flowTasks   FlowTask[]
  memoryItems MemoryItem[]
  leads       Lead[]
  opportunities Opportunity[]
  outreachDrafts OutreachDraft[]
  opportunityQuotes OpportunityQuote[]
  adminAuditLogs    AdminAuditLog[]
  notifications     UserNotification[]
  digitalAudits     DigitalAudit[]
  auditSheetQueue   AuditSheetQueueItem[]
  financeEntries    FinanceEntry[]
  outreachSequences OutreachSequence[]
  clientMilestones  ClientMilestone[]
  referrers         Referrer[]
  timeEntries       TimeEntry[]
  timeEntriesApproved TimeEntry[] @relation("TimeEntryApprovedBy")
  timeEntriesSecondApproved TimeEntry[] @relation("TimeEntrySecondApprovedBy")
  automationRules   AutomationRule[]
  automationRuleRevisions AutomationRuleRevision[]
  automationFlowRuns AutomationFlowRun[]
  workspaceAuditLogs WorkspaceAuditLog[]
  automationRuleTemplates AutomationRuleTemplate[]
  dedupeScanRuns    DedupeScanRun[]
  regiaDailySheets  RegiaDailySheet[]
  intelligenceRecommendations IntelligenceRecommendation[]
  retailContracts   ClientRetailContract[]
  timeErpPushLogs   TimeErpPushLog[]
  workspace         Workspace? @relation(fields: [workspaceId], references: [id], onDelete: SetNull)
  whatsAppAssigned  WhatsAppInboundMessage[] @relation("WhatsAppAssignee")
  clientOnboardingItems ClientOnboardingItem[]
  clientCommitments     ClientCommitment[]
  assistantChatThreads  AssistantChatThread[]
  aiRuns                AiRun[]
  people                Person[]
}

/// Workspace / tenant leggero (MVP multi-agenzia).
model Workspace {
  id        String   @id @default(cuid())
  slug      String   @unique
  name      String
  /// Se true, query clienti filtrano strettamente per workspaceId (multi-agenzia).
  isolated  Boolean  @default(false)
  /// Slug per futuro schema DB dedicato (enterprise).
  databaseSlug String? @unique
  /// Connection string PostgreSQL dedicata (override env map).
  databaseUrl  String? @db.Text
  /// Ultimo `prisma migrate deploy` riuscito sul DB tenant.
  databaseProvisionedAt DateTime?
  /// supabase | rds — provisioning cloud automatico.
  databaseCloudProvider String?
  databaseCloudRef      String?
  createdAt DateTime @default(now())

  users      User[]
  clients    Client[]
  auditLogs  WorkspaceAuditLog[]
}

enum DedupeTrainingJobStatus {
  PENDING
  RUNNING
  DONE
  FAILED
}

/// Job training dedupe (export GPU / webhook esterno / fallback CPU cron).
model DedupeTrainingJob {
  id             String                  @id @default(cuid())
  status         DedupeTrainingJobStatus @default(PENDING)
  pairsCount     Int                     @default(0)
  datasetS3Key   String?
  datasetUrl     String?                 @db.Text
  gpuWebhookUrl  String?                 @db.Text
  weightsVersion Int?
  errorDetail    String?                 @db.Text
  createdAt      DateTime                @default(now())
  startedAt      DateTime?
  completedAt    DateTime?

  @@index([status, createdAt])
}

/// Certificazioni partner ERP (UI + override env).
model AgencyPartnerSettings {
  id                      String    @id @default("default")
  zucchettiOfficial       Boolean   @default(false)
  sapOfficial             Boolean   @default(false)
  zucchettiPartnerRef     String?
  sapPartnerRef           String?
  zucchettiContractDriveUrl String?
  sapContractDriveUrl       String?
  legalArchiveNotes         String?   @db.Text
  contractSignedAt          DateTime?
  updatedAt                 DateTime  @updatedAt
}

/// Pesi / config modello dedupe custom (training pipeline).
model DedupeModelConfig {
  id           String   @id @default("default")
  version      Int      @default(1)
  weightsJson  String?  @db.Text
  datasetNotes String?  @db.Text
  updatedAt    DateTime @updatedAt
}

/// Dead-letter coda automazioni (fallimenti definitivi).
model AutomationFlowRunDeadLetter {
  id          String   @id @default(cuid())
  flowRunId   String?
  ruleId      String
  ownerUserId String
  payloadJson String   @db.Text
  errorDetail String?  @db.Text
  createdAt   DateTime @default(now())

  @@index([createdAt])
}

enum AutomationRuleTrigger {
  POST_APPROVED
  LEAD_CREATED
  TICKET_CREATED
  FINANCE_OVERDUE_SNAPSHOT
  REACH_DRAFT_SENT
  FINANCE_INCOME_CREATED
  WHATSAPP_INBOUND
}

/// Azioni sensibili admin (MVP audit trail).
model AdminAuditLog {
  id           String   @id @default(cuid())
  actorUserId  String?
  action       String
  entityType   String?
  entityId     String?
  summary      String
  metadataJson String?  @db.Text
  createdAt    DateTime @default(now())

  actor User? @relation(fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([actorUserId])
  @@index([createdAt])
}

/// Notifiche in-app per utente (portale cliente MVP).
model UserNotification {
  id        String    @id @default(cuid())
  userId    String
  kind      String
  title     String
  body      String?   @db.Text
  href      String?
  readAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, readAt])
  @@index([userId, createdAt])
}

/// Token OAuth cifrati per integrazioni per-utente admin.
model UserOAuthConnection {
  id           String        @id @default(cuid())
  userId       String
  provider     OAuthProvider
  accountEmail String?
  tokenCipher  String        @db.Text
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, provider])
  @@index([userId])
}

model Client {
  id           String       @id @default(cuid())
  companyName  String
  slug         String       @unique
  contactEmail String
  status       ClientStatus @default(ACTIVE_CLIENT)
  /// Privato vs azienda (inferito da CF/P.IVA se assente).
  kind               ClientKind?
  fiscalCode         String?
  clientMacroCategory ClientMacroCategory?
  notes        String?      @db.Text
  vatNumber    String?
  phone        String?
  website      String?
  address      String?
  city         String?
  country        String       @default("IT")
  driveFolderUrl String?
  /// Conto PDC gestionale per export finance (es. 4105001)
  accountingCode String?
  /// Embedding OpenAI per dedupe ML persistente (float[]).
  dedupeEmbedding  Float[]  @default([])
  /// ANN pgvector (sync da dedupeEmbedding quando ONIZUKA_PGVECTOR attivo).
  dedupeEmbeddingVector Unsupported("vector(1536)")?
  /// Ore SLA ticket portale per questo cliente (override globale TICKET_SLA_HOURS).
  ticketSlaHours   Int?
  workspaceId      String?  @default("ws_default")
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  workspace    Workspace? @relation(fields: [workspaceId], references: [id], onDelete: SetNull)
  users        User[]
  posts        PostItem[]
  webhooks     WebhookSubscription[]
  flowTasks    FlowTask[]
  memoryItems  MemoryItem[]
  opportunities Opportunity[]
  convertedFromLead Lead? @relation("LeadConversion")
  assets       Asset[]
  contacts     ClientContact[]
  tickets         ClientTicket[]
  outreachDrafts  OutreachDraft[]
  outreachSequences OutreachSequence[]
  commercialServices ClientCommercialService[]
  digitalAudits      DigitalAudit[]
  financeEntries     FinanceEntry[]
  milestones         ClientMilestone[]
  onboardingItems    ClientOnboardingItem[]
  commitments        ClientCommitment[]
  timeEntries        TimeEntry[]
  retailContracts    ClientRetailContract[]
  socialInboxComments SocialInboxComment[]
  personRoles        PersonClientRole[]

  @@index([status])
  @@index([kind])
  @@index([clientMacroCategory])
  @@index([vatNumber])
  @@index([fiscalCode])
}

enum RetailContractKind {
  MOBILE
  ENERGY
  SKY
  OTHER
}

enum RetailContractStatus {
  ACTIVE
  EXPIRED
  CANCELLED
}

/// Contratto retail (telefonia, energia, Sky…) collegato al cliente.
model ClientRetailContract {
  id             String               @id @default(cuid())
  clientId       String
  ownerUserId    String
  kind           RetailContractKind   @default(OTHER)
  label          String
  monthlyEur     Decimal              @db.Decimal(12, 2)
  renewalDate    DateTime?
  status         RetailContractStatus @default(ACTIVE)
  /// Voce Finance MRR collegata (sync automatico).
  financeEntryId String?
  notes          String?              @db.Text
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)
  owner  User   @relation(fields: [ownerUserId], references: [id], onDelete: Cascade)

  @@index([clientId])
  @@index([ownerUserId])
  @@index([renewalDate])
}

/// Registro tempo lavorato (MVP timesheet interno).
model TimeEntry {
  id          String   @id @default(cuid())
  ownerUserId String
  clientId    String?
  description String   @db.Text
  minutes     Int
  workedAt    DateTime @default(now())
  billable          Boolean   @default(true)
  hourlyRateEur     Decimal?  @db.Decimal(10, 2)
  /// Codice commessa / progetto per export gestionale.
  projectCode       String?
  approvedAt        DateTime?
  approvedByUserId  String?
  /// Seconda approvazione (four-eyes): deve essere un ADMIN diverso dal primo.
  secondApprovedAt       DateTime?
  secondApprovedByUserId String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  owner      User    @relation(fields: [ownerUserId], references: [id], onDelete: Cascade)
  client     Client? @relation(fields: [clientId], references: [id], onDelete: SetNull)
  approvedBy User?   @relation("TimeEntryApprovedBy", fields: [approvedByUserId], references: [id], onDelete: SetNull)
  secondApprovedBy User? @relation("TimeEntrySecondApprovedBy", fields: [secondApprovedByUserId], references: [id], onDelete: SetNull)

  @@index([ownerUserId, workedAt])
  @@index([approvedAt])
  @@index([secondApprovedAt])
}

/// Regole automazione in-app (MVP: post approvato → Telegram).
model AutomationRule {
  id               String                 @id @default(cuid())
  ownerUserId      String
  name             String
  trigger          AutomationRuleTrigger
  /// Ordine esecuzione: valori minori = prima.
  priority         Int                    @default(100)
  enabled          Boolean                @default(true)
  notifyTelegram   Boolean                @default(false)
  /// Condizione if/then base (uguaglianza): es. key=platform, value=FACEBOOK.
  conditionKey     String?
  /// Operatore condizione (EQ, NEQ, GT, GTE, LT, LTE, CONTAINS, STARTS_WITH, ENDS_WITH, IN, DATE_BEFORE, DATE_AFTER).
  conditionOperator String                @default("EQ")
  conditionValue   String?
  /// Invia email SMTP (best-effort) al destinatario specificato.
  notifyEmail      Boolean                @default(false)
  notifyEmailTo    String?
  /// Template opzionali con placeholder {{key}} (es. {{trigger}}, {{clientName}}).
  emailSubjectTemplate String?            @db.Text
  emailBodyTemplate    String?            @db.Text
  /// POST JSON (trigger + payload) verso URL esterno (n8n / Zapier).
  webhookUrl       String?                @db.Text
  /// Payload JSON opzionale (template) per webhook; fallback = payload base.
  webhookPayloadTemplate String?          @db.Text
  /// Retry azioni (email/webhook): tentativi extra oltre al primo invio.
  actionRetryAttempts Int                 @default(0)
  /// Secondi base per backoff esponenziale (1,2,4,...) sui retry.
  actionRetryBackoffSec Int               @default(2)
  /// Crea un task Flow collegato al cliente (solo trigger con clientId: ticket/lead; non usato per snapshot finance).
  createFlowTask   Boolean                @default(false)
  flowTaskTitle    String?                @db.Text
  /// Branch multipli stile n8n (JSON: { branches: [{ id, label, conditionKey, ... }] }).
  flowBranchesJson String?                @db.Text
  /// Grafo visuale flow builder (versionamento flusso).
  visualFlowJson   String?                @db.Text
  ruleVersion      Int                    @default(1)
  createdAt        DateTime               @default(now())
  updatedAt        DateTime               @updatedAt

  owner User @relation(fields: [ownerUserId], references: [id], onDelete: Cascade)
  executions AutomationRuleExecution[]
  revisions  AutomationRuleRevision[]
  flowRuns   AutomationFlowRun[]

  @@index([ownerUserId])
}

/// Step coda automazione (runtime distribuito stile n8n).
model AutomationFlowRun {
  id           String                  @id @default(cuid())
  ruleId       String
  ownerUserId  String
  branchId     String?
  status       AutomationFlowRunStatus @default(PENDING)
  payloadJson  String                  @db.Text
  scheduledAt  DateTime                @default(now())
  startedAt    DateTime?
  completedAt  DateTime?
  errorDetail  String?                 @db.Text
  attemptCount Int                     @default(0)

  rule  AutomationRule @relation(fields: [ruleId], references: [id], onDelete: Cascade)
  owner User           @relation(fields: [ownerUserId], references: [id], onDelete: Cascade)

  @@index([status, scheduledAt])
  @@index([ruleId])
}

/// Audit operazioni per workspace (multi-agenzia).
model WorkspaceAuditLog {
  id           String   @id @default(cuid())
  workspaceId  String
  actorUserId  String?
  action       String
  entityType   String?
  entityId     String?
  summary      String
  metadataJson String?  @db.Text
  createdAt    DateTime @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  actor     User?     @relation(fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([workspaceId, createdAt])
}

/// Snapshot storico regola prima di ogni modifica.
model AutomationRuleRevision {
  id              String   @id @default(cuid())
  ruleId          String
  version         Int
  snapshotJson    String   @db.Text
  createdByUserId String?
  createdAt       DateTime @default(now())

  rule    AutomationRule @relation(fields: [ruleId], references: [id], onDelete: Cascade)
  creator User?          @relation(fields: [createdByUserId], references: [id], onDelete: SetNull)

  @@index([ruleId, version])
}

enum DedupeScanStatus {
  PENDING
  RUNNING
  DONE
  FAILED
}

/// Esecuzione scansione dedupe (full fuzzy) in background.
model DedupeScanRun {
  id                  String           @id @default(cuid())
  ownerUserId         String
  status              DedupeScanStatus @default(PENDING)
  fuzzyIndexedClients Int              @default(10000)
  groupCount          Int?
  summaryJson         String?          @db.Text
  errorDetail         String?          @db.Text
  startedAt           DateTime         @default(now())
  completedAt         DateTime?
  alertEmailSentAt      DateTime?

  owner User @relation(fields: [ownerUserId], references: [id], onDelete: Cascade)

  @@index([ownerUserId, startedAt])
}

/// Template regola automazione salvato / condiviso tra admin.
model AutomationRuleTemplate {
  id           String   @id @default(cuid())
  ownerUserId  String
  name         String
  snapshotJson String   @db.Text
  shared       Boolean  @default(false)
  /// Visibile a tutti gli admin come template marketplace (import copia).
  marketplace  Boolean  @default(false)
  createdAt    DateTime @default(now())

  owner User @relation(fields: [ownerUserId], references: [id], onDelete: Cascade)

  @@index([ownerUserId])
  @@index([shared])
  @@index([marketplace])
}

/// Log esecuzioni regole automazione (audit operativo).
model AutomationRuleExecution {
  id           String   @id @default(cuid())
  ruleId       String
  channel      String
  success      Boolean  @default(false)
  attemptCount Int      @default(1)
  errorDetail  String?  @db.Text
  payloadJson  String?  @db.Text
  createdAt    DateTime @default(now())

  rule AutomationRule @relation(fields: [ruleId], references: [id], onDelete: Cascade)

  @@index([ruleId, createdAt])
  @@index([createdAt])
}

/// Referente / contatto commerciale lato agenzia (scheda cliente 360°).
model ClientContact {
  id        String   @id @default(cuid())
  clientId  String
  name      String
  role      String?
  email     String?
  phone     String?
  isPrimary Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([clientId])
}

/// Persona fisica (entità CRM) collegabile a più aziende.
model Person {
  id          String   @id @default(cuid())
  ownerUserId String
  fullName    String
  email       String?
  phone       String?
  fiscalCode  String?
  notes       String?  @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  owner       User               @relation(fields: [ownerUserId], references: [id], onDelete: Cascade)
  clientRoles PersonClientRole[]

  @@index([ownerUserId])
  @@index([email])
  @@index([fiscalCode])
}

/// Relazione persona ↔ azienda (ruolo, referente primario).
model PersonClientRole {
  id        String   @id @default(cuid())
  personId  String
  clientId  String
  role      String?
  isPrimary Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  person Person @relation(fields: [personId], references: [id], onDelete: Cascade)
  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@unique([personId, clientId])
  @@index([clientId])
  @@index([personId])
}

/// Presenza digitale / brand collegato a un cliente (social, GBP, sito gestito…).
model Asset {
  id          String    @id @default(cuid())
  clientId    String
  name        String
  slug        String
  platform    Platform?
  profileUrl      String?
  /// Resource name GBP: accounts/…/locations/… (risposte recensioni per asset).
  gbpLocationName String?
  notes           String?   @db.Text
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  client          Client          @relation(fields: [clientId], references: [id], onDelete: Cascade)
  opportunities   Opportunity[]
  memoryItems     MemoryItem[]
  financeEntries    FinanceEntry[]

  @@unique([clientId, slug])
  @@index([clientId])
}

/// Segnalatore / referral (servizi office).
model Referrer {
  id              String   @id @default(cuid())
  ownerUserId     String
  name            String
  email           String?
  phone           String?
  commissionNotes String?  @db.Text
  /// Percentuale provvigione su valore opportunità WON collegate ai clienti convertiti dai lead del segnalatore (0–100).
  commissionPercent Decimal? @db.Decimal(5, 2)
  /// PIN portale segnalatore (hash bcrypt) per accesso dashboard oltre al token URL.
  portalPinHash   String?
  /// IBAN per liquidazioni provvigioni (mostrato mascherato sul portale).
  payoutIban      String?
  active          Boolean  @default(true)
  /// Token opzionale per form pubblico segnalatore (`/refer?t=…`).
  submissionToken String?  @unique
  /// Email Google collegata per SSO portale (`/api/refer/oauth/google`).
  googleEmail       String?  @unique
  /// Email Microsoft collegata per SSO portale (`/api/refer/oauth/microsoft`).
  microsoftEmail    String?  @unique
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  owner   User             @relation(fields: [ownerUserId], references: [id], onDelete: Cascade)
  leads   Lead[]
  payouts ReferrerPayout[]
  magicLinks ReferrerMagicLink[]
  pushSubscriptions ReferrerPushSubscription[]

  @@index([ownerUserId])
}

/// Link monouso per accesso portale senza PIN (magic link email).
model ReferrerMagicLink {
  id         String    @id @default(cuid())
  referrerId String
  token      String    @unique
  expiresAt  DateTime
  usedAt     DateTime?
  createdAt  DateTime  @default(now())

  referrer Referrer @relation(fields: [referrerId], references: [id], onDelete: Cascade)

  @@index([referrerId, expiresAt])
}

/// Web Push subscription portale segnalatore.
model ReferrerPushSubscription {
  id         String   @id @default(cuid())
  referrerId String
  endpoint   String   @unique
  p256dh     String
  auth       String
  createdAt  DateTime @default(now())

  referrer Referrer @relation(fields: [referrerId], references: [id], onDelete: Cascade)

  @@index([referrerId])
}

/// Liquidazione provvigioni verso segnalatore.
model ReferrerPayout {
  id          String               @id @default(cuid())
  referrerId  String
  amountEur   Decimal              @db.Decimal(12, 2)
  status      ReferrerPayoutStatus @default(PENDING)
  periodLabel String?
  paidAt      DateTime?
  /// Riferimento bonifico / CRO.
  paymentReference String?
  /// URL ricevuta o documento liquidazione (Drive, PDF hosted).
  documentUrl      String?
  notes       String?              @db.Text
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt

  referrer Referrer @relation(fields: [referrerId], references: [id], onDelete: Cascade)

  @@index([referrerId, createdAt])
}

model Lead {
  id                  String     @id @default(cuid())
  title               String
  contactName         String?
  businessName        String?
  email               String?
  phone               String?
  vatNumber           String?
  fiscalCode          String?
  clientMacroCategory ClientMacroCategory?
  commercialProspectStage CommercialProspectStage?
  source              String?
  referrerId          String?
  status              LeadStatus @default(NEW)
  notes               String?    @db.Text
  ownerUserId         String
  convertedClientId   String?    @unique
  website             String?
  city                String?
  /// Google Places place_id (segnale forte, non sostituto P.IVA).
  googlePlaceId       String?
  createdAt           DateTime   @default(now())
  updatedAt           DateTime   @updatedAt

  owner            User      @relation(fields: [ownerUserId], references: [id], onDelete: Cascade)
  referrer         Referrer? @relation(fields: [referrerId], references: [id], onDelete: SetNull)
  convertedClient  Client?   @relation("LeadConversion", fields: [convertedClientId], references: [id], onDelete: SetNull)
  outreachDrafts   OutreachDraft[]
  outreachSequences OutreachSequence[]
  followups         LeadFollowup[]
  digitalAudits     DigitalAudit[] @relation("AuditLead")
  opportunities    Opportunity[]

  @@index([ownerUserId])
  @@index([status])
  @@index([referrerId])
  @@index([googlePlaceId])
  @@index([ownerUserId, googlePlaceId])
}

/// Follow-up programmato su lead (walk-in, enrichment).
model LeadFollowup {
  id           String    @id @default(cuid())
  leadId       String
  type         String    @default("general")
  scheduledAt  DateTime
  notes        String?   @db.Text
  outcome      String?   @default("pending")
  completedAt  DateTime?
  createdAt    DateTime  @default(now())

  lead Lead @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@index([leadId])
  @@index([scheduledAt])
}

/// Agenda giornaliera regia operativa (port StationHQ).
model RegiaDailySheet {
  id           String    @id @default(cuid())
  ownerUserId  String
  day          DateTime  @db.Date
  payload      Json      @default("{}")
  closedAt     DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  owner User @relation(fields: [ownerUserId], references: [id], onDelete: Cascade)

  @@unique([ownerUserId, day])
  @@index([ownerUserId, day])
}

/// Raccomandazione intelligence (NBA) persistita.
model IntelligenceRecommendation {
  id          String    @id @default(cuid())
  ownerUserId String
  kind        String
  title       String
  detail      String?   @db.Text
  href        String?
  priority    String    @default("medium")
  dismissedAt DateTime?
  createdAt   DateTime  @default(now())

  owner User @relation(fields: [ownerUserId], references: [id], onDelete: Cascade)

  @@index([ownerUserId, dismissedAt])
  @@index([createdAt])
}

model Opportunity {
  id              String              @id @default(cuid())
  clientId        String?
  leadId          String?
  assetId         String?
  title           String
  description     String?             @db.Text
  status          OpportunityStatus   @default(OPEN)
  priority        OpportunityPriority @default(MEDIUM)
  estimatedValue  Decimal?            @db.Decimal(12, 2)
  probability     Int?
  nextAction      String?
  dueDate         DateTime?
  ownerUserId     String
  /// Origine (es. DIGITAL_AUDIT).
  source          String?
  /// Audit che ha generato l'opportunità.
  digitalAuditId  String?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  owner  User   @relation(fields: [ownerUserId], references: [id], onDelete: Cascade)
  client Client? @relation(fields: [clientId], references: [id], onDelete: Cascade)
  lead   Lead?  @relation(fields: [leadId], references: [id], onDelete: SetNull)
  asset  Asset? @relation(fields: [assetId], references: [id], onDelete: SetNull)
  quotes OpportunityQuote[]

  @@index([ownerUserId])
  @@index([clientId])
  @@index([leadId])
  @@index([status])
  @@index([assetId])
  @@index([digitalAuditId])
  @@index([source])
}

/// Preventivo commerciale collegato a un'opportunità (MVP).
model OpportunityQuote {
  id            String      @id @default(cuid())
  opportunityId String
  ownerUserId   String
  title         String
  status        QuoteStatus @default(DRAFT)
  linesJson     String      @db.Text
  taxPercent    Int         @default(22)
  notes         String?     @db.Text
  validUntil    DateTime?
  sentAt        DateTime?
  /// Reminder «proposta non risposta» (giorni lavorativi dopo invio).
  noResponseDueAt DateTime?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  opportunity Opportunity @relation(fields: [opportunityId], references: [id], onDelete: Cascade)
  owner       User        @relation(fields: [ownerUserId], references: [id], onDelete: Cascade)

  @@index([opportunityId])
  @@index([ownerUserId])
  @@index([status])
  @@index([noResponseDueAt])
}

model PostItem {
  id                    String     @id @default(cuid())
  clientId              String
  platform              Platform
  captionText           String     @default("")
  status                PostStatus @default(PENDING)
  scheduledFor          DateTime?
  publishedAt           DateTime?  // Set when n8n marks as published
  publishUrl            String?    // URL post live (Social Pro)
  impressions           Int?
  reach                 Int?
  engagement            Int?
  externalRef           String?    // External ID from n8n/social platform
  awaitingClientReview  Boolean    @default(true)
  createdAt             DateTime   @default(now())
  updatedAt             DateTime   @updatedAt
  createdByUserId       String?

  client   Client       @relation(fields: [clientId], references: [id], onDelete: Cascade)
  media    MediaAsset[]
  comments Comment[]
}

model MediaAsset {
  id          String    @id @default(cuid())
  postItemId  String
  type        MediaType
  url         String
  thumbnailUrl String?
  filename    String
  mimeType    String
  sizeBytes   Int
  createdAt   DateTime  @default(now())

  postItem PostItem @relation(fields: [postItemId], references: [id], onDelete: Cascade)
}

model Comment {
  id         String   @id @default(cuid())
  postItemId String
  userId     String
  body       String
  createdAt  DateTime @default(now())

  postItem PostItem @relation(fields: [postItemId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model WebhookSubscription {
  id        String       @id @default(cuid())
  clientId  String?      // null = all clients (admin-level)
  event     WebhookEvent
  targetUrl String
  secret    String
  isActive  Boolean      @default(true)
  createdAt DateTime     @default(now())

  client     Client?           @relation(fields: [clientId], references: [id], onDelete: Cascade)
  deliveries WebhookDelivery[]
}

/// Coda consegne webhook fallite (dead-letter) con retry manuale admin.
model WebhookDelivery {
  id             String                @id @default(cuid())
  subscriptionId String
  postItemId     String?
  event          WebhookEvent
  targetUrl      String
  httpStatus     Int
  errorDetail    String?               @db.Text
  payloadJson    String                @db.Text
  status         WebhookDeliveryStatus @default(FAILED)
  attempts       Int                   @default(1)
  nextRetryAt    DateTime?
  lastAttemptAt  DateTime              @default(now())
  deliveredAt    DateTime?
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt

  subscription WebhookSubscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)

  @@index([subscriptionId])
  @@index([status])
  @@index([createdAt])
}

model FlowTask {
  id              String           @id @default(cuid())
  title           String
  description     String?
  status          FlowTaskStatus   @default(TODO)
  priority        FlowTaskPriority @default(MEDIUM)
  dueDate         DateTime?
  source          String           @default("manual")
  relatedClientId String?
  ownerUserId     String
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  owner  User    @relation(fields: [ownerUserId], references: [id], onDelete: Cascade)
  client Client? @relation(fields: [relatedClientId], references: [id], onDelete: SetNull)

  @@index([ownerUserId])
  @@index([status])
}

model MemoryItem {
  id              String             @id @default(cuid())
  scope           MemoryScope
  title           String
  content         String             @db.Text
  tags            String[]           @default([])
  relatedClientId String?
  relatedAssetId  String?
  sensitivity     MemorySensitivity  @default(LOW)
  source          MemorySource       @default(MANUAL)
  ownerUserId     String
  contentEncrypted Boolean           @default(false)
  /// Embedding OpenAI (text-embedding-3-small) per ricerca semantica.
  embedding       Float[]
  /// pgvector (1536 dim) — sincronizzato da embedding[] se extension attiva.
  embeddingVector Unsupported("vector(1536)")?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  owner  User    @relation(fields: [ownerUserId], references: [id], onDelete: Cascade)
  client Client? @relation(fields: [relatedClientId], references: [id], onDelete: SetNull)
  asset  Asset?  @relation(fields: [relatedAssetId], references: [id], onDelete: SetNull)

  @@index([ownerUserId])
  @@index([scope])
  @@index([relatedClientId])
  @@index([relatedAssetId])
}

/// Ticket supporto dal portale cliente.
model ClientTicket {
  id              String       @id @default(cuid())
  clientId        String
  title           String
  body            String       @db.Text
  status          TicketStatus @default(OPEN)
  createdByUserId String?
  clientReadAt    DateTime?
  /// Scadenza SLA (es. +48h da apertura).
  slaDueAt        DateTime?
  slaBreachedAt   DateTime?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  client      Client                   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  updates     ClientTicketUpdate[]
  attachments ClientTicketAttachment[]

  @@index([clientId])
  @@index([status])
  @@index([slaDueAt])
}

model ClientTicketAttachment {
  id               String   @id @default(cuid())
  ticketId         String
  updateId         String?
  filename         String
  url              String
  mimeType         String
  sizeBytes        Int
  uploadedByUserId String?
  createdAt        DateTime @default(now())

  ticket ClientTicket        @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  update ClientTicketUpdate? @relation(fields: [updateId], references: [id], onDelete: SetNull)

  @@index([ticketId])
  @@index([updateId])
}

/// Aggiornamento stato o nota admin visibile al cliente sul ticket.
model ClientTicketUpdate {
  id              String        @id @default(cuid())
  ticketId        String
  message         String?       @db.Text
  status          TicketStatus?
  createdByUserId String?
  clientReadAt    DateTime?
  createdAt       DateTime      @default(now())

  ticket      ClientTicket             @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  attachments ClientTicketAttachment[]

  @@index([ticketId])
}

/// Bozza outreach (nessun invio automatico senza approvazione).
model OutreachDraft {
  id             String              @id @default(cuid())
  ownerUserId    String
  clientId       String?
  leadId         String?
  digitalAuditId String?
  sequenceStepId String?             @unique
  subject        String
  subjectAlt     String?
  bodyAlt        String?             @db.Text
  abVariantSent  String?
  abWinner       String?
  body           String              @db.Text
  status         OutreachDraftStatus @default(DRAFT)
  sentAt         DateTime?
  openedAt       DateTime?
  openCount      Int                 @default(0)
  clickedAt      DateTime?
  clickCount     Int                 @default(0)
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt

  owner        User                  @relation(fields: [ownerUserId], references: [id], onDelete: Cascade)
  client       Client?               @relation(fields: [clientId], references: [id], onDelete: SetNull)
  lead         Lead?                 @relation(fields: [leadId], references: [id], onDelete: SetNull)
  digitalAudit DigitalAudit?         @relation(fields: [digitalAuditId], references: [id], onDelete: SetNull)
  sequenceStep OutreachSequenceStep? @relation(fields: [sequenceStepId], references: [id], onDelete: SetNull)

  @@index([ownerUserId])
  @@index([status])
  @@index([digitalAuditId])
  @@index([sentAt])
}

/// Sequenza commerciale multi-step (J+0, J+3, J+7) con bozze in approvazione.
model OutreachSequence {
  id             String                 @id @default(cuid())
  ownerUserId    String
  clientId       String?
  leadId         String?
  digitalAuditId String?                @unique
  name           String
  status         OutreachSequenceStatus @default(ACTIVE)
  createdAt      DateTime               @default(now())
  updatedAt      DateTime               @updatedAt

  owner        User                   @relation(fields: [ownerUserId], references: [id], onDelete: Cascade)
  client       Client?                @relation(fields: [clientId], references: [id], onDelete: SetNull)
  lead         Lead?                  @relation(fields: [leadId], references: [id], onDelete: SetNull)
  digitalAudit DigitalAudit?          @relation(fields: [digitalAuditId], references: [id], onDelete: SetNull)
  steps        OutreachSequenceStep[]

  @@index([ownerUserId])
  @@index([status])
  @@index([clientId])
}

model OutreachSequenceStep {
  id              String                     @id @default(cuid())
  sequenceId      String
  stepIndex       Int
  delayDays       Int
  subject         String
  subjectAlt      String?
  body            String                     @db.Text
  bodyAlt         String?                    @db.Text
  status          OutreachSequenceStepStatus @default(SCHEDULED)
  scheduledFor    DateTime
  activatedAt     DateTime?
  createdAt       DateTime                   @default(now())
  updatedAt       DateTime                   @updatedAt

  sequence      OutreachSequence @relation(fields: [sequenceId], references: [id], onDelete: Cascade)
  outreachDraft OutreachDraft?

  @@unique([sequenceId, stepIndex])
  @@index([sequenceId])
  @@index([status, scheduledFor])
}

/// Brand dell'ecosistema Lorenzo (LabSeven, StudioPop…) — memoria commerciale strutturata.
model EcosystemBrand {
  id                        String   @id @default(cuid())
  slug                      String   @unique
  name                      String
  domain                    String?
  mission                   String?  @db.Text
  positioning               String?  @db.Text
  toneOfVoice               String?  @db.Text
  /// Template oggetto email proposta (placeholder: {{companyName}}, {{brandName}}).
  proposalEmailSubjectTemplate String?
  proposalEmailBodyTemplate    String?  @db.Text
  commercialLeversJson      String?  @db.Text
  idealUseCasesJson         String?  @db.Text
  differencesFromOthersJson String?  @db.Text
  ecosystemRole             String?  @db.Text
  notes                     String?  @db.Text
  sortOrder                 Int      @default(0)
  createdAt                 DateTime @default(now())
  updatedAt                 DateTime @updatedAt

  commercialServices CommercialService[]
  digitalAudits      DigitalAudit[]

  @@index([sortOrder])
}

/// Servizio vendibile nel catalogo Onizuka.
model CommercialService {
  id                 String                    @id @default(cuid())
  slug               String                    @unique
  name               String
  category           CommercialServiceCategory @default(OTHER)
  ecosystemBrandId   String?
  description        String?                   @db.Text
  sortOrder          Int                       @default(0)
  createdAt          DateTime                  @default(now())
  updatedAt          DateTime                  @updatedAt

  ecosystemBrand EcosystemBrand?          @relation(fields: [ecosystemBrandId], references: [id], onDelete: SetNull)
  clientLinks    ClientCommercialService[]
  digitalAudits  DigitalAudit[]

  @@index([category])
  @@index([ecosystemBrandId])
}

/// Servizio attivo o mancante per un cliente (scheda 360°).
model ClientCommercialService {
  id                  String   @id @default(cuid())
  clientId            String
  commercialServiceId String
  active              Boolean  @default(false)
  notes               String?  @db.Text
  since               DateTime?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  client            Client            @relation(fields: [clientId], references: [id], onDelete: Cascade)
  commercialService CommercialService @relation(fields: [commercialServiceId], references: [id], onDelete: Cascade)

  @@unique([clientId, commercialServiceId])
  @@index([clientId])
}

/// Audit digitale da P.IVA / scheda cliente (protocollo marketing).
model DigitalAudit {
  id                    String             @id @default(cuid())
  ownerUserId           String
  clientId              String?
  leadId                String?
  vatNumber             String?
  businessName          String?
  website               String?
  status                DigitalAuditStatus @default(PENDING)
  overallScore          Int?
  priorityProblem       String?            @db.Text
  recommendedBrandId    String?
  recommendedServiceId  String?
  internalNotes           String?            @db.Text
  internalReportDriveUrl  String?
  clientReportDriveUrl    String?
  gbpRating               Float?
  gbpReviewCount          Int?
  gbpPlaceName            String?
  /// Token URL-safe per report pubblico prospect (`/report/[token]`).
  publicReportToken       String?            @unique
  publicReportExpiresAt   DateTime?
  outreachLinkedInBody    String?            @db.Text
  outreachCallScript      String?            @db.Text
  createdAt               DateTime           @default(now())
  updatedAt               DateTime           @updatedAt

  owner              User                  @relation(fields: [ownerUserId], references: [id], onDelete: Cascade)
  client             Client?               @relation(fields: [clientId], references: [id], onDelete: SetNull)
  lead               Lead?                 @relation("AuditLead", fields: [leadId], references: [id], onDelete: SetNull)
  recommendedBrand   EcosystemBrand?     @relation(fields: [recommendedBrandId], references: [id], onDelete: SetNull)
  recommendedService CommercialService?  @relation(fields: [recommendedServiceId], references: [id], onDelete: SetNull)
  sections           DigitalAuditSection[]
  outreachDrafts     OutreachDraft[]
  outreachSequence   OutreachSequence?

  @@index([ownerUserId])
  @@index([clientId])
  @@index([leadId])
  @@index([status])
  @@index([createdAt])
}

/// Riga importata da Google Sheet in coda per audit digitale (EP03).
model AuditSheetQueueItem {
  id              String                @id @default(cuid())
  ownerUserId     String
  vatNumber       String?
  businessName    String?
  contactEmail    String?
  website         String?
  city            String?
  /// Chiave stabile riga (P.IVA / dominio / nome+città) per dedupe import.
  sheetRowKey     String
  status          AuditSheetQueueStatus @default(PENDING)
  errorDetail     String?               @db.Text
  digitalAuditId  String?
  clientId        String?
  createdAt       DateTime              @default(now())
  processedAt     DateTime?

  owner User @relation(fields: [ownerUserId], references: [id], onDelete: Cascade)

  @@unique([ownerUserId, sheetRowKey])
  @@index([ownerUserId, status])
  @@index([status, createdAt])
}

model DigitalAuditSection {
  id             String                 @id @default(cuid())
  digitalAuditId String
  sectionKey     DigitalAuditSectionKey
  score          Int
  positives      String?                @db.Text
  issues         String?                @db.Text
  createdAt      DateTime               @default(now())

  digitalAudit DigitalAudit @relation(fields: [digitalAuditId], references: [id], onDelete: Cascade)

  @@unique([digitalAuditId, sectionKey])
  @@index([digitalAuditId])
}

/// Voce finanziaria (entrate/uscite) — complemento alla pipeline CRM.
model FinanceEntry {
  id          String             @id @default(cuid())
  ownerUserId String
  clientId    String?
  assetId     String?
  type        FinanceEntryType
  status      FinanceEntryStatus @default(PLANNED)
  label         String
  amountEur     Decimal            @db.Decimal(12, 2)
  /// Se true e tipo INCOME: importo conteggiato nel MRR/forecast ricorrente.
  recurringMonthly Boolean         @default(false)
  /// Prossimo rinnovo contratto/ricorrenza (forecast).
  renewalDate      DateTime?
  invoiceNumber String?
  dueDate       DateTime?
  paidAt        DateTime?
  sdiExportedAt           DateTime?
  stripeCheckoutSessionId String?
  notes                   String?            @db.Text
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt

  owner  User    @relation(fields: [ownerUserId], references: [id], onDelete: Cascade)
  client Client? @relation(fields: [clientId], references: [id], onDelete: SetNull)
  asset  Asset?  @relation(fields: [assetId], references: [id], onDelete: SetNull)

  @@unique([ownerUserId, invoiceNumber])
  @@index([ownerUserId])
  @@index([type])
  @@index([status])
  @@index([dueDate])
  @@index([renewalDate])
  @@index([assetId])
}

/// Voce checklist onboarding cliente (raccolta materiali, kickoff, ecc.).
model ClientOnboardingItem {
  id          String    @id @default(cuid())
  clientId    String
  ownerUserId String
  label       String
  sortOrder   Int       @default(0)
  status      String    @default("pending")
  dueDate     DateTime?
  completedAt DateTime?
  notes       String?   @db.Text
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)
  owner  User   @relation(fields: [ownerUserId], references: [id], onDelete: Cascade)

  @@index([clientId])
  @@index([ownerUserId, status])
}

/// Impegno / promessa verso il cliente (commitment tracker).
model ClientCommitment {
  id          String    @id @default(cuid())
  clientId    String
  ownerUserId String
  title       String
  note        String?   @db.Text
  ownerName   String?
  dueDate     DateTime?
  status      String    @default("open")
  completedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)
  owner  User   @relation(fields: [ownerUserId], references: [id], onDelete: Cascade)

  @@index([clientId])
  @@index([ownerUserId, status])
  @@index([dueDate])
}

/// Thread chat assistente Onizuka (admin).
model AssistantChatThread {
  id          String   @id @default(cuid())
  ownerUserId String
  title       String   @default("Nuova chat")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  owner    User                   @relation(fields: [ownerUserId], references: [id], onDelete: Cascade)
  messages AssistantChatMessage[]

  @@index([ownerUserId, updatedAt])
}

model AssistantChatMessage {
  id        String   @id @default(cuid())
  threadId  String
  role      String
  content   String   @db.Text
  createdAt DateTime @default(now())

  thread AssistantChatThread @relation(fields: [threadId], references: [id], onDelete: Cascade)

  @@index([threadId, createdAt])
}

/// Log esecuzioni AI (assistente, audit batch, ecc.).
model AiRun {
  id            String   @id @default(cuid())
  ownerUserId   String
  kind          String
  status        String   @default("completed")
  inputSummary  String?  @db.Text
  outputSummary String?  @db.Text
  errorDetail   String?  @db.Text
  createdAt     DateTime @default(now())

  owner User @relation(fields: [ownerUserId], references: [id], onDelete: Cascade)

  @@index([ownerUserId, createdAt])
  @@index([kind])
}

/// Milestone progetto visibile nel portale cliente.
model ClientMilestone {
  id              String    @id @default(cuid())
  clientId        String
  ownerUserId     String
  title           String
  description     String?   @db.Text
  targetDate      DateTime?
  completedAt     DateTime?
  visibleToClient Boolean   @default(true)
  sortOrder       Int       @default(0)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)
  owner  User   @relation(fields: [ownerUserId], references: [id], onDelete: Cascade)

  @@index([clientId])
  @@index([ownerUserId])
}

/// Log push ore verso ERP esterno.
model TimeErpPushLog {
  id         String   @id @default(cuid())
  ownerUserId String
  vendor     String
  entryCount Int
  ok         Boolean
  errorDetail String? @db.Text
  createdAt  DateTime @default(now())

  owner User @relation(fields: [ownerUserId], references: [id], onDelete: Cascade)

  @@index([ownerUserId, createdAt])
}

/// Commento social registrato manualmente o da integrazione futura.
model SocialInboxComment {
  id              String    @id @default(cuid())
  platform        Platform
  clientId        String?
  authorName      String?
  body            String    @db.Text
  externalId      String?   @unique
  externalUrl     String?
  replyBody       String?   @db.Text
  replyExternalId String?
  repliedAt       DateTime?
  receivedAt      DateTime  @default(now())

  client Client? @relation(fields: [clientId], references: [id], onDelete: SetNull)

  @@index([receivedAt])
  @@index([clientId])
}

/// Messaggio WhatsApp in ingresso (webhook Meta).
model WhatsAppInboundMessage {
  id             String    @id @default(cuid())
  waMessageId    String?   @unique
  phoneFrom      String
  body           String?   @db.Text
  phoneLineId    String?
  phoneNumberId  String?
  assignedUserId String?
  repliedAt      DateTime?
  receivedAt     DateTime  @default(now())
  rawJson        String?   @db.Text

  phoneLine WhatsAppPhoneLine?       @relation(fields: [phoneLineId], references: [id], onDelete: SetNull)
  assignee  User?                    @relation("WhatsAppAssignee", fields: [assignedUserId], references: [id], onDelete: SetNull)
  outbound  WhatsAppOutboundMessage[]

  @@index([receivedAt])
  @@index([assignedUserId])
  @@index([phoneLineId])
  @@index([phoneNumberId])
}

/// Messaggio WhatsApp inviato (risposta operatore).
model WhatsAppOutboundMessage {
  id               String   @id @default(cuid())
  inboundMessageId String?
  phoneTo          String
  body             String   @db.Text
  templateName     String?
  sentByUserId     String?
  createdAt        DateTime @default(now())

  inbound WhatsAppInboundMessage? @relation(fields: [inboundMessageId], references: [id], onDelete: SetNull)

  @@index([inboundMessageId])
  @@index([createdAt])
}

/// Catalogo template HSM (nome Meta + anteprima).
model WhatsAppTemplate {
  id           String   @id @default(cuid())
  name         String
  languageCode String   @default("it")
  bodyPreview  String   @db.Text
  category     String?
  createdAt    DateTime @default(now())

  @@unique([name, languageCode])
}

/// Linea WhatsApp Business (multi phone_number_id).
model WhatsAppPhoneLine {
  id            String   @id @default(cuid())
  label         String
  phoneNumberId String   @unique
  wabaId        String?
  isDefault     Boolean  @default(false)
  createdAt     DateTime @default(now())

  inbound WhatsAppInboundMessage[]

  @@index([isDefault])
}
