// Onizuka — schema operativo (MVP in evoluzione verso master spec).
// Multi-tenant: admin vs client; moduli Flow (task), CRM (clienti), approvazioni contenuti, webhook n8n.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  ADMIN
  STAFF
  CLIENT
}

enum Platform {
  FACEBOOK
  INSTAGRAM
  LINKEDIN
  GBP
}

enum PostStatus {
  PENDING
  APPROVED
  NEEDS_REVISION
}

enum MediaType {
  IMAGE
  VIDEO
}

/// Come è stato collegato l'account social del cliente (Publisher multi-tenant).
enum SocialConnectionMode {
  MANAGED // Lorenzo è admin del Business Manager del cliente e collega lui l'account
  SELF // il cliente ha autorizzato via OAuth dal proprio account
}

enum SocialAccountStatus {
  CONNECTED
  EXPIRED
  REVOKED
}

/// Fonte dati del modulo Analytics (social + sito + advertising).
enum AnalyticsSource {
  INSTAGRAM
  FACEBOOK
  LINKEDIN
  GBP
  TIKTOK
  YOUTUBE
  GA4
  GOOGLE_ADS
  META_ADS
}

enum WebhookEvent {
  POST_APPROVED
  POST_STATUS_CHANGED
}

enum WebhookDeliveryStatus {
  FAILED
  DELIVERED
}

enum OAuthProvider {
  GOOGLE_CALENDAR
  GMAIL
  GOOGLE_GBP
  GOOGLE_ANALYTICS
  ZUCCHETTI_ERP
  SAP_ERP
}

enum AutomationFlowRunStatus {
  PENDING
  RUNNING
  DONE
  FAILED
}

enum FlowTaskStatus {
  TODO
  IN_PROGRESS
  WAITING
  DONE
  CANCELLED
}

enum FlowTaskPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum MemoryScope {
  PERSONAL
  BUSINESS
  ASSET
  CLIENT
  EPISODIC
  DOCUMENTAL
  SENSITIVE
}

enum MemorySensitivity {
  LOW
  MEDIUM
  HIGH
}

enum MemorySource {
  MANUAL
  VOICE
  CHAT
  DOCUMENT
  SYSTEM
}

enum ClientStatus {
  LEAD_COLD
  LEAD_QUALIFIED
  CONTACTED
  INTERESTED
  APPOINTMENT_SET
  QUOTE_SENT
  NEGOTIATION
  ACTIVE_CLIENT
  DORMANT
  LOST
  TO_REACTIVATE
}

/// Privato (CF) vs azienda (P.IVA) — PUNTO-SITUA-DEFINITIVO.
enum ClientKind {
  PRIVATE
  BUSINESS
}

/// Stato relazione semplice e cambiabile a mano in qualsiasi momento.
/// LEAD = prospect (audit/sheet, NON in lista clienti) · CLIENTE = cliente vero · EX_CLIENTE = ex.
enum ClientRelationshipState {
  LEAD
  CLIENTE
  EX_CLIENTE
}

/// Macro-categoria commerciale cliente.
enum ClientMacroCategory {
  RETAIL_STORE
  DIGITAL_AI
  MIXED
}

/// Stati funnel prospect digitali/AI (workflow P.IVA).
enum CommercialProspectStage {
  PROSPECT_ENTERED
  AUDIT_IN_PROGRESS
  AUDIT_COMPLETED
  REPORT_GENERATED
  PROPOSAL_GENERATED
  AWAITING_SEND_APPROVAL
  FIRST_AUDIT_MAIL_SENT
  FOLLOW_UP_SCHEDULED
  FOLLOW_UP_SENT
  RESPONSE_RECEIVED
  CALL_SCHEDULED
  QUOTE_SENT
  IN_NEGOTIATION
  WON
  LOST
  NURTURING
}

enum LeadStatus {
  NEW
  COLD
  QUALIFIED
  CONTACTED
  CONVERTED
  LOST
}

enum ReferrerPayoutStatus {
  PENDING
  PAID
}

enum OpportunityStatus {
  OPEN
  WON
  LOST
  PAUSED
}

enum OpportunityPriority {
  LOW
  MEDIUM
  HIGH
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

enum OutreachDraftStatus {
  DRAFT
  PENDING_APPROVAL
  APPROVED
  SENT
  CANCELLED
}

enum OutreachSequenceStatus {
  ACTIVE
  PAUSED
  COMPLETED
  CANCELLED
}

enum OutreachSequenceStepStatus {
  SCHEDULED
  ACTIVATED
  SENT
  SKIPPED
  CANCELLED
